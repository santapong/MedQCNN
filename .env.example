# ──────────────────────────────────────────────
# MedQCNN — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────

# ── Database ─────────────────────────────────
# PostgreSQL (production):
DATABASE_URL=postgresql://medqcnn:medqcnn@localhost:5432/medqcnn
# SQLite (development fallback — used when DATABASE_URL is not set):
# DATABASE_URL=sqlite:///medqcnn.db

# ── API Server ───────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Model Configuration ─────────────────────
# Path to a trained model checkpoint (optional):
# CHECKPOINT_PATH=checkpoints/model_final.pt
# Number of qubits (default: 4 for demo, 8 for production):
# N_QUBITS=4

# ── Authentication (Phase 6) ───────────────────
# Secret key for JWT token signing (CHANGE IN PRODUCTION):
JWT_SECRET_KEY=change-me-to-a-random-secret
# Single API key for edge deployment (alternative to DB-stored keys):
# MEDQCNN_API_KEY=your-api-key-here
# Set to 1 to disable auth entirely (dev mode only):
# MEDQCNN_AUTH_DISABLED=1
# CORS allowed origins (comma-separated, default: *):
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# ── Kafka (optional, for async pipeline) ─────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_REQUEST_TOPIC=medqcnn.inference.request
KAFKA_RESULT_TOPIC=medqcnn.inference.result

# ── LangChain Agent (optional) ───────────────
# Required only if using the LangGraph ReAct agent:
# OPENAI_API_KEY=sk-...

# ── Docker Compose Overrides ─────────────────
POSTGRES_USER=medqcnn
POSTGRES_PASSWORD=medqcnn
POSTGRES_DB=medqcnn
